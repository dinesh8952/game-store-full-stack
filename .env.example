# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://gamestore_user:gamestore_pass@postgres:5432/gamestore_db
POSTGRES_USER=gamestore_user
POSTGRES_PASSWORD=gamestore_pass
POSTGRES_DB=gamestore_db

# ── Redis ─────────────────────────────────────────────────────
# Password must match REDIS_PASSWORD below
REDIS_URL=redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# ── JWT ───────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32
JWT_EXPIRES_IN=15m

# ── App ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Super Admin Seed ─────────────────────────────────────────
# REQUIRED — must be at least 12 chars, mixed case + symbols
# Generate with: openssl rand -base64 16
SUPER_ADMIN_EMAIL=admin@gamestore.com
SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
